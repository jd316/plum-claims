GEMINI_API_KEY=          # REQUIRED — your Google Gemini API key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
DATABASE_URL=postgresql+psycopg://plum:plum@localhost:5432/claims

# Postgres credentials for the Docker stack. Default to `plum` for zero-config local use;
# SET A STRONG POSTGRES_PASSWORD FOR ANY REAL DEPLOY. The compose file composes the
# backend/worker DATABASE_URL from these, so they stay in sync automatically.
# POSTGRES_USER=plum
# POSTGRES_PASSWORD=plum
# POSTGRES_DB=claims

# Optional overrides (sane defaults in app/config.py):
# POLICY_PATH=policy_terms.json
# TEST_CASES_PATH=test_cases.json
# STORAGE_DIR=storage
# DEGRADATION_PENALTY=0.20

# Async processing (Celery + self-hosted Redis). Broker + result-backend default to REDIS_URL.
# REDIS_URL=redis://localhost:6379/0

# Deployment environment marker. "production" turns insecure security defaults
# (dev JWT secret with auth on, empty PHI key with encryption on) into a hard boot
# refusal; "development" (default) only logs a warning.
# APP_ENV=development

# Self-issued JWT auth + RBAC (OFF by default — see README "Authentication & RBAC").
# AUTH_ENABLED=false
# JWT_SECRET=dev-insecure-change-me      # OVERRIDE in production (and set APP_ENV=production)
# Login-page wayfinding only: show an Operator|Member toggle (placeholder + role blurb;
# no auto-fill, no passwords, does not change auth). OFF for true-prod; turn ON for a
# review/demo deployment so both roles are discoverable.
# SHOW_ROLE_HELP=false

# Object storage abstraction. "local" (default) stores uploads on disk under STORAGE_DIR;
# "minio" routes them through a self-hosted S3-compatible MinIO (start with `--profile minio`).
# OBJECT_STORE=local
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=claims

# Transparent at-rest PHI encryption (OFF by default). When enabled, set a strong key
# (else a weak dev key is derived from JWT_SECRET with a warning).
# PHI_ENCRYPTION_ENABLED=false
# PHI_ENCRYPTION_KEY=

# Additive feature toggles (sane defaults in app/config.py):
# CONFIDENCE_CALIBRATION_ENABLED=false   # map composite confidence through a fitted calibrator
# RESILIENCE_ENABLED=true                # circuit breaker / fallback / concurrency cap on failure
# ADAPTIVE_ROUTING_ENABLED=true          # supervisor fans out only to applicable rule agents

# Optional LangSmith tracing (env-gated; the app runs perfectly without it).
# Set BOTH to get the technical execution tree in LangSmith on top of the in-app
# domain trace. Leave commented to keep tracing fully disabled (no-op).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=plum-claims
